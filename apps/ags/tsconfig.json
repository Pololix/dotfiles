{
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "paths": {
      "ags/*": [
        "./node_modules/ags/*"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}